#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	int t;
	cin >> t;
	while(t--){
	    int n;
	    cin >> n;
	    vector<int> a(n),c(n);
	    	    vector<pair<int,int>> co;

	    for(int i=0;i<n;i++){
	        cin >> a[i];
	    }
	    for(int i=0;i<n;i++){
	        cin >> c[i];
	        co.push_back({c[i],i});
	    }
	    int ans=0;
        sort(co.begin(),co.end());
        for(int i=0;i<n;i++){
            int val=co[i].first;
            int in=co[i].second;
            for(int j=in;j<n;j++){
                if(a[j]==-1) continue;
                else {
                    ans+=(val*a[j]);
                    a[j]=-1;
                }
            }
        }
        cout << ans << endl;
	}

}
